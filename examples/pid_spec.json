{
  "version": "v1",
  "model": {
    "name": "PIDDemo",
    "description": "PID controller driving a transfer function plant",
    "sourcePrompt": "Create a PID controller with a transfer function plant and scope"
  },
  "blocks": [
    {
      "id": "Reference",
      "type": "Inport",
      "position": [40, 130, 70, 150]
    },
    {
      "id": "ErrorSum",
      "type": "Sum",
      "params": {
        "Inputs": "+-"
      },
      "position": [120, 120, 150, 150]
    },
    {
      "id": "Kp",
      "type": "Gain",
      "params": {
        "Gain": "1.0"
      },
      "position": [220, 60, 270, 90]
    },
    {
      "id": "Ki",
      "type": "Integrator",
      "position": [220, 120, 250, 150]
    },
    {
      "id": "Kd",
      "type": "Derivative",
      "position": [220, 180, 250, 210]
    },
    {
      "id": "ControlSum",
      "type": "Sum",
      "params": {
        "Inputs": "+++"
      },
      "position": [320, 115, 350, 155]
    },
    {
      "id": "Plant",
      "type": "TransferFcn",
      "params": {
        "Numerator": "[1]",
        "Denominator": "[1 1]"
      },
      "position": [420, 120, 500, 150]
    },
    {
      "id": "Output",
      "type": "Outport",
      "position": [600, 130, 630, 150]
    },
    {
      "id": "Scope",
      "type": "Scope",
      "position": [600, 40, 630, 70]
    }
  ],
  "connections": [
    {"srcBlock": "Reference", "srcPort": 1, "dstBlock": "ErrorSum", "dstPort": 1},
    {"srcBlock": "ErrorSum", "srcPort": 1, "dstBlock": "Kp", "dstPort": 1},
    {"srcBlock": "ErrorSum", "srcPort": 1, "dstBlock": "Ki", "dstPort": 1},
    {"srcBlock": "ErrorSum", "srcPort": 1, "dstBlock": "Kd", "dstPort": 1},
    {"srcBlock": "Kp", "srcPort": 1, "dstBlock": "ControlSum", "dstPort": 1},
    {"srcBlock": "Ki", "srcPort": 1, "dstBlock": "ControlSum", "dstPort": 2},
    {"srcBlock": "Kd", "srcPort": 1, "dstBlock": "ControlSum", "dstPort": 3},
    {"srcBlock": "ControlSum", "srcPort": 1, "dstBlock": "Plant", "dstPort": 1},
    {"srcBlock": "Plant", "srcPort": 1, "dstBlock": "Output", "dstPort": 1},
    {"srcBlock": "Plant", "srcPort": 1, "dstBlock": "Scope", "dstPort": 1},
    {"srcBlock": "Plant", "srcPort": 1, "dstBlock": "ErrorSum", "dstPort": 2}
  ],
  "simulation": {
    "stopTime": "10",
    "solver": "ode45"
  },
  "validation": {
    "compileCheck": true,
    "smokeTest": true
  }
}
